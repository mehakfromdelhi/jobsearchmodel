generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                 String?
  betaAccessGranted    Boolean               @default(false)
  emailVerifiedAt      DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  profile              Profile?
  matchingPreferences  MatchingPreferences?
  resumeVariants       ResumeVariant[]
  scanRuns             ScanRun[]
  jobs                 Job[]
  applications         Application[]
  generatedMaterials   GeneratedMaterial[]
  dashboardConnections DashboardConnection[]
  magicLinkTokens      MagicLinkToken[]
  feedbackItems        Feedback[]
}

model MagicLinkToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  id               String   @id @default(cuid())
  userId           String   @unique
  headline         String?
  location         String?
  timezone         String?  @default("America/New_York")
  targetSeniority  String?
  industries       Json?
  companies        Json?
  remotePreference String?
  onboardingCompletedAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MatchingPreferences {
  id                 String   @id @default(cuid())
  userId             String   @unique
  targetFunctions    Json
  positiveKeywords   Json
  negativeKeywords   Json
  conceptMatches     Json
  preferredLocations Json
  includeRemote      Boolean  @default(true)
  freshnessDays      Int      @default(5)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResumeVariant {
  id                 String   @id @default(cuid())
  userId             String
  name               String
  slug               String
  intendedRoleFamily String?
  contentMarkdown    String
  isActive           Boolean  @default(false)
  isTailored         Boolean  @default(false)
  sourceJobId        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceJob          Job?     @relation(fields: [sourceJobId], references: [id], onDelete: SetNull)

  @@unique([userId, slug])
}

model ScanRun {
  id           String   @id @default(cuid())
  userId       String
  status       String
  summary      String?
  jobsFound    Int      @default(0)
  jobsPromoted Int      @default(0)
  createdAt    DateTime @default(now())
  completedAt  DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs         Job[]
}

model Job {
  id                     String    @id @default(cuid())
  userId                 String
  scanRunId              String?
  company                String
  role                   String
  sourceUrl              String
  sourcePlatform         String?
  workflowState          String
  freshnessStatus        String?
  postedDate             DateTime?
  freshnessSource        String?
  relevanceScore         Float?
  companyPriority        String?
  location               String?
  investorFundingSummary String?
  jdSummary              String?
  fullDescription        String?
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scanRun                ScanRun?  @relation(fields: [scanRunId], references: [id], onDelete: SetNull)
  applications           Application[]
  generatedMaterials     GeneratedMaterial[]
  tailoredResumes        ResumeVariant[]

  @@unique([userId, sourceUrl])
}

model Application {
  id         String   @id @default(cuid())
  userId     String
  jobId      String   @unique
  status     String
  appliedAt  DateTime?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model GeneratedMaterial {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  kind      String
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model DashboardConnection {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  status       String
  externalId   String?
  settingsJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  message   String
  context   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
